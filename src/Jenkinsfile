pipeline {
    agent any 

    options {
        skipDefaultCheckout()
    }

    stages {
        stage('Paso 1: Preparar') {
            steps {
                bat 'cd /d "C:\\DesarrolloWeb2\\ProyectoFac" && npm install'
            }
        }
        stage('Paso 2: Probar') {
            steps {
                bat 'cd /d "C:\\DesarrolloWeb2\\ProyectoFac" && npx ng test --watch=false --browsers=ChromeHeadless'
            }
        }
        stage('Paso 3: Copiar resultados') {
            steps {
                bat 'copy C:\\DesarrolloWeb2\\ProyectoFac\\test-results\\*.xml %WORKSPACE%'
            }
        }
    }

    post {
        always {
            junit '*.xml'
        }
    }
}