pipeline {
    agent any 
    stages {
        stage('Paso 1: Preparar') {
            steps {
                bat 'cd /d "C:\\DesarrolloWeb2\\ProyectoFac" && npm install'
            }
        }
        stage('Paso 2: Probar') {
            steps {
                bat '''
                    cd /d "C:\\DesarrolloWeb2\\ProyectoFac"
                    
                    :: 1. Ejecutar tests
                    call npx ng test --watch=false --browsers=ChromeHeadless
                    
                    :: 2. Verificamos si el archivo existe en tu carpeta
                    if exist "test-results\\results.xml" (
                        echo === ARCHIVO ENCONTRADO EN PROYECTOFAC ===
                        :: 3. Lo copiamos a la carpeta donde Jenkins está trabajando actualmente
                        copy /Y "test-results\\results.xml" "%WORKSPACE%\\results.xml"
                    ) else (
                        echo === ERROR: EL ARCHIVO NO SE GENERO EN PROYECTOFAC ===
                    )
                '''
            }
        }
    }
    post {
        always {
            // Ahora le pedimos a Jenkins que busque el archivo que acabamos de copiar a su Workspace
            junit 'results.xml'
        }
    }
}