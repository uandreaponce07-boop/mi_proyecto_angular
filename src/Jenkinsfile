pipeline {
    agent any 
    
    options {
        skipDefaultCheckout() 
    }

    stages {
        stage('Paso 1: Preparar') {
            steps {
                bat 'cd /d "C:\\DesarrolloWeb2\\ProyectoFac" && npm install'
            }
        }
       stage('Paso 2: Probar') {
            steps {
                bat '''
                    cd /d "C:\\DesarrolloWeb2\\ProyectoFac"
                    
                    :: 1. Corremos los tests (esto genera el results.xml en tu carpeta C:)
                    call npx ng test --watch=false --browsers=ChromeHeadless
                    
                    :: 2. Forzamos la copia del archivo al Workspace de Jenkins
                    :: Usamos %WORKSPACE% para que Jenkins sepa que es 'su' carpeta
                    copy /Y "C:\\DesarrolloWeb2\\ProyectoFac\\test-results\\results.xml" "results.xml"
                    
                    :: 3. Verificamos que se copió (esto saldrá en el log de Jenkins)
                    dir results.xml
                '''
            }
        }
    }
    
    post {
        always {
            // Ahora Jenkins lo busca en su propia raíz
            junit 'results.xml'
        }
    }